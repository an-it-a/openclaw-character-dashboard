# Copy this file to .env.local and adjust values for your environment.
# .env.local is gitignored and will NOT be committed.

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
# Root directory of your OpenClaw installation/config.
# Used to locate openclaw.json and, by default, the shared resource wall files.
# Default: ~/.openclaw
# OPENCLAW_HOME=~/.openclaw

# Port for the local OpenClaw API server (used by the dev-server proxy).
# Default: 3001
#
# VITE_API_PORT=3001

# How long a recent user-facing session keeps an agent in the "working" state.
# Default: 10000 (10 seconds)
# VITE_SESSION_ACTIVE_THRESHOLD_MS=10000

# ---------------------------------------------------------------------------
# Asset pack directory
# ---------------------------------------------------------------------------
# Path to the directory served as the Vite public root.
# All static assets (world.json, clip-defs.json, images/) must live here.
# Supports absolute paths and paths relative to the project root.
# Default: ./public
#
# VITE_PUBLIC_DIR=./public
# VITE_PUBLIC_DIR=./public_frieren
# VITE_PUBLIC_DIR=/Users/yourname/my-asset-pack
# VITE_PUBLIC_DIR=../shared-assets/pack-a

# ---------------------------------------------------------------------------
# Shared files root
# ---------------------------------------------------------------------------
# Path to the directory the resource wall file browser serves.
# Supports absolute paths and paths relative to the project root.
# Default: <OPENCLAW_HOME>/shared
#
# SHARED_ROOT=~/.openclaw/shared
# SHARED_ROOT=/path/to/custom/shared
